# ==========================================
# Frontend Nuxt 3 設定
# ==========================================
# Cloudflare Turnstile 前端金鑰 (用於防止機器人)
NUXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Google Analytics 追蹤 ID
NUXT_PUBLIC_GTAG_ID=G-XXXXXXXXXX

# Docker 內部通訊用 (通常不需更改，除非您的 backend 服務名稱不同)
# BACKEND_URL=http://backend:8002


# ==========================================
# Backend FastAPI 設定
# ==========================================
# --- 系統與安全 ---
# 執行環境 (development / production)
ENVIRONMENT=production

# CORS 允許來源 (以逗號分隔，生產環境請填上正式網域)
CORS_ORIGINS=https://opendgpa.shibaalin.com

# 網站正式 Domain（前後端 SEO/canonical/sitemap 必須一致）
SITE_DOMAIN=https://opendgpa.shibaalin.com
NUXT_PUBLIC_SITE_URL=https://opendgpa.shibaalin.com

# 安全相關金鑰 (建議產生足夠長度的隨機字串)
CSRF_SECRET_KEY=your_csrf_secret_key

# 驗證機制 Secret (Cloudflare Turnstile 或 Google Recaptcha)
CLOUDFLARE_TURNSTILE_SECRET_KEY=your_turnstile_secret_key
GOOGLE_RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key


# --- 資料庫 ---
# 預設使用 SQLite，會自動掛載於 backend/database/data/job_info.db
# 如果您要改用 MySQL，請取消註解下方設定並填入正確資訊，否則請保持註解
# DATABASE_URL=mysql+aiomysql://root:password@db_host:3306/job_info


# --- 第三方服務整合 ---
# 事求人公開資料來源網址
JOB_DATA_URL=https://www.dgpa.gov.tw/op/want/wantjob_today.xml


